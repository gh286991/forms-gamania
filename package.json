{
  "name": "appscript",
  "version": "1.0.0",
  "description": "Google Apps Script TypeScript project using clasp.",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "login": "clasp login",
    "push": "clasp push --force",
    "open": "clasp open-script",
    "open:web": "clasp open-web-app",
    "deploy": "npm run build && npm run push && node scripts/deploy.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "postcss": "^8.5.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.4"
  },
  "keywords": [
    "google-apps-script",
    "clasp",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.8",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "esbuild": "^0.28.0",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

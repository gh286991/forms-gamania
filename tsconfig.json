{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "types": ["google-apps-script"],
    "noEmit": true,
    "skipLibCheck": true
  },
    "include": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.mjs"]
}
